{
    "name": "components",
    "private": true,
    "license": "MIT",
    "packageManager": "npm@10.9.8",
    "engines": {
        "node": ">=22"
    },
    "scripts": {
        "format": "prettier --write .",
        "format:check": "prettier --check .",
        "registry:build": "rm -rf public/r && mkdir -p public/r && shadcn build",
        "registry:validate": "shadcn registry validate",
        "registry:list": "shadcn list GDanielRG/components",
        "registry:check": "npm run format:check && npm run registry:validate && npm run registry:build",
        "registry:release": "node scripts/release.mjs",
        "smoke": "node scripts/smoke-baseline.mjs",
        "test": "vitest run"
    },
    "devDependencies": {
        "@base-ui/react": "^1.6.0",
        "@inertiajs/core": "^3.5.0",
        "@inertiajs/react": "^3.5.0",
        "@testing-library/dom": "^10.4.1",
        "@testing-library/jest-dom": "^6.9.1",
        "@testing-library/react": "^16.3.2",
        "@types/react": "^19.2.17",
        "@types/react-dom": "^19.2.3",
        "class-variance-authority": "^0.7.1",
        "clsx": "^2.1.1",
        "jsdom": "^29.1.1",
        "lucide-react": "^1.25.0",
        "prettier": "3.9.5",
        "react": "^19.2.7",
        "react-dom": "^19.2.7",
        "shadcn": "4.11.0",
        "tailwind-merge": "^3.6.0",
        "vitest": "^4.1.8"
    }
}
